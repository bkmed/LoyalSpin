{
  "eslint.options": {
    "extensions": [".js", ".jsx", ".ts", ".tsx"],
    "ignorePath": ".eslintignore"
  },
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/node_modules": false
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/build": true,
    "**/dist": true
  },
  "typescript": {
  "validate":{"enable": true},
  "tsdk": "node_modules/typescript/lib"
  },
  "github.copilot.chat.anthropic.tools.websearch.enabled": true
}
